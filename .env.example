# =============================================================================
# VIT Housing — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# In Docker/production, these are provided via docker-compose environment vars.
# =============================================================================

# --- Database (REQUIRED) ---
DATABASE_URL=postgresql://user:password@localhost:5432/vithousing

# --- Encryption key for service config secrets stored in DB (REQUIRED) ---
# Generate with: openssl rand -base64 32
CONFIG_ENCRYPTION_KEY=your-config-encryption-key-change-this

# --- JWT authentication (REQUIRED in production) ---
JWT_SECRET=your-jwt-secret-change-this

# --- Server ---
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Client (Vite — baked in at build time) ---
VITE_AUTH0_DOMAIN=your-tenant.eu.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
VITE_AUTH0_AUDIENCE=https://api.vithousing.example.com
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_API_BASE_URL=http://localhost:3000

# =============================================================================
# The following services can also be configured via the Admin UI (stored
# encrypted in the database). Environment variables serve as fallbacks.
# =============================================================================

# --- Auth0 (server-side) ---
# AUTH0_DOMAIN=your-tenant.eu.auth0.com
# AUTH0_CLIENT_ID=your-auth0-client-id
# AUTH0_CLIENT_SECRET=your-auth0-client-secret
# AUTH0_AUDIENCE=https://api.vithousing.example.com

# --- AWS (SES email) ---
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# SES_FROM_ADDRESS=noreply@yourdomain.com

# --- Google Maps (server-side geocoding) ---
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Invitation emails ---
# INVITATION_BASE_URL=http://localhost:5173

# --- Legacy Drupal migration (one-time use) ---
# DRUPAL_DB_URL=mysql://user:password@localhost:3306/drupal_db
# Required to run Drupal import preflight or migration locally.
# DRUPAL_IMPORT_MYSQL_HOST=127.0.0.1
# DRUPAL_IMPORT_MYSQL_PORT=3306
# DRUPAL_IMPORT_MYSQL_USER=root
# DRUPAL_IMPORT_MYSQL_PASSWORD=your-password
# DRUPAL_IMPORT_MYSQL_DATABASE=drupal_import_temp
